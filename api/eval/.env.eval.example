# 评测专用模型配置（复制为 .env.eval 并填真实值；.env.eval 不进 git）
# 评测直接用这里的 key 建 client，不依赖 app 的「用户 + 模型配置表」。

# Embedding 模型（必需）——维度需与 ES 索引一致（默认 1024，见 app 的 EMBEDDING_DIMS）
EVAL_EMBED_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EVAL_EMBED_MODEL=model_name
EVAL_EMBED_KEY=your_key

# 对话模型（必需：记忆萃取 / 去重判定用）
EVAL_CHAT_BASE_URL=https://api.deepseek.com
EVAL_CHAT_MODEL=model_name
EVAL_CHAT_KEY=your_key

# Rerank 模型（可选：不填则跳过「混合+rerank」对比列）
# 注意：必须是 OpenAI/Jina 风格的 rerank 端点——程序会向 {BASE_URL}/rerank 发请求，
#       并按 {"results":[{"index","relevance_score"}]} 解析。
#       ✓ 可用：SiliconFlow（https://api.siliconflow.cn/v1 + 模型 BAAI/bge-reranker-v2-m3）、Jina、Cohere 兼容网关。
#       ✗ 不可用：阿里云百炼 DashScope —— 它的 rerank 走原生 API（非 OpenAI 兼容），本程序调不通。
EVAL_RERANK_BASE_URL=https://api.siliconflow.cn/v1
EVAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
EVAL_RERANK_KEY=your_key
