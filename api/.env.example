# ============ 应用 ============
APP_NAME=Comet
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# 前端地址，用于 CORS
CORS_ORIGINS=http://localhost:5173

# ============ 安全 ============
# JWT 签名密钥，生产请改成随机长字符串
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# API Key 对称加密密钥（Fernet，44 位 base64），生成：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ============ PostgreSQL ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=comet
POSTGRES_PASSWORD=comet
POSTGRES_DB=comet

# ============ Elasticsearch ============
ES_HOST=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# ============ Neo4j ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cometneo4j

# ============ Redis / Celery ============
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============ 文件存储 ============
STORAGE_DIR=./storage
